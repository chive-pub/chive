{
  "lexicon": 1,
  "id": "pub.chive.admin.getBackfillHistory",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get history of completed, failed, and cancelled backfill operations",
      "parameters": {
        "type": "params",
        "properties": {}
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["operations"],
          "properties": {
            "operations": {
              "type": "array",
              "items": { "type": "ref", "ref": "#backfillOperation" },
              "description": "Historical backfill operations"
            }
          }
        }
      },
      "errors": [{ "name": "AuthenticationRequired" }, { "name": "AdminRequired" }]
    },
    "backfillOperation": {
      "type": "object",
      "description": "A backfill operation record",
      "required": ["id", "type", "status", "startedAt", "recordsProcessed"],
      "properties": {
        "id": { "type": "string", "description": "Operation ID" },
        "type": {
          "type": "string",
          "knownValues": [
            "pds-scan",
            "freshness-scan",
            "citation-extraction",
            "full-reindex",
            "governance-sync",
            "did-sync"
          ],
          "description": "Backfill operation type"
        },
        "status": {
          "type": "string",
          "knownValues": ["completed", "failed", "cancelled"],
          "description": "Operation status"
        },
        "startedAt": {
          "type": "string",
          "format": "datetime",
          "description": "Operation start time"
        },
        "completedAt": {
          "type": "string",
          "format": "datetime",
          "description": "Operation completion time"
        },
        "recordsProcessed": {
          "type": "integer",
          "description": "Number of records processed"
        },
        "totalRecords": {
          "type": "integer",
          "description": "Total records to process"
        },
        "error": { "type": "string", "description": "Error message if failed" },
        "startedBy": {
          "type": "string",
          "format": "did",
          "description": "DID of the admin who started it"
        }
      }
    }
  }
}
