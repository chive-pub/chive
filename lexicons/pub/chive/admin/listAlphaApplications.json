{
  "lexicon": 1,
  "id": "pub.chive.admin.listAlphaApplications",
  "revision": 2,
  "defs": {
    "main": {
      "type": "query",
      "description": "List alpha tester applications with optional status filter and pagination",
      "parameters": {
        "type": "params",
        "properties": {
          "status": {
            "type": "string",
            "knownValues": ["pending", "approved", "rejected", "revoked"],
            "description": "Filter by application status"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items", "total"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#alphaApplication"
              },
              "description": "Alpha applications"
            },
            "total": {
              "type": "integer",
              "description": "Total matching applications"
            },
            "cursor": {
              "type": "string",
              "description": "Pagination cursor for the next page"
            }
          }
        }
      },
      "errors": [
        {
          "name": "AuthenticationRequired"
        },
        {
          "name": "AdminRequired"
        }
      ]
    },
    "researchKeyword": {
      "type": "object",
      "description": "Research keyword with optional Wikidata link",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Keyword label"
        },
        "wikidataId": {
          "type": "string",
          "description": "Wikidata entity ID"
        }
      }
    },
    "alphaApplication": {
      "type": "object",
      "description": "Alpha tester application record",
      "required": [
        "id",
        "did",
        "email",
        "status",
        "sector",
        "careerStage",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Application UUID"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "Applicant DID"
        },
        "handle": {
          "type": "string",
          "description": "Applicant handle"
        },
        "email": {
          "type": "string",
          "description": "Contact email"
        },
        "status": {
          "type": "string",
          "knownValues": ["pending", "approved", "rejected", "revoked"],
          "description": "Application status"
        },
        "sector": {
          "type": "string",
          "description": "Organization sector"
        },
        "sectorOther": {
          "type": "string",
          "description": "Custom sector if other"
        },
        "careerStage": {
          "type": "string",
          "description": "Career stage"
        },
        "careerStageOther": {
          "type": "string",
          "description": "Custom career stage if other"
        },
        "affiliations": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "pub.chive.defs#affiliation"
          },
          "description": "Institutional affiliations"
        },
        "researchKeywords": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#researchKeyword"
          },
          "description": "Research keywords"
        },
        "motivation": {
          "type": "string",
          "description": "Motivation statement"
        },
        "zulipInvited": {
          "type": "boolean",
          "description": "Whether a Zulip invite was sent"
        },
        "reviewedAt": {
          "type": "string",
          "format": "datetime",
          "description": "Review timestamp"
        },
        "reviewedBy": {
          "type": "string",
          "description": "Reviewer DID"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "Application creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "description": "Last update timestamp"
        }
      }
    }
  }
}
