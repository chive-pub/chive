{
  "lexicon": 1,
  "id": "pub.chive.admin.listWarnings",
  "defs": {
    "main": {
      "type": "query",
      "description": "List user warnings",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of warnings"
          },
          "did": {
            "type": "string",
            "format": "did",
            "description": "Filter by user DID"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["warnings", "total"],
          "properties": {
            "warnings": {
              "type": "array",
              "items": { "type": "ref", "ref": "#warning" },
              "description": "Warning records"
            },
            "total": {
              "type": "integer",
              "description": "Total warnings"
            }
          }
        }
      },
      "errors": [{ "name": "AuthenticationRequired" }, { "name": "AdminRequired" }]
    },
    "warning": {
      "type": "object",
      "description": "User warning record",
      "required": ["id", "did", "reason", "issuedBy", "createdAt"],
      "properties": {
        "id": { "type": "string", "description": "Warning ID" },
        "did": { "type": "string", "format": "did", "description": "Warned user DID" },
        "handle": { "type": "string", "description": "Warned user handle" },
        "reason": { "type": "string", "description": "Reason for the warning" },
        "issuedBy": {
          "type": "string",
          "format": "did",
          "description": "Admin DID who issued the warning"
        },
        "expiresAt": {
          "type": "string",
          "format": "datetime",
          "description": "Warning expiry timestamp"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the warning was issued"
        }
      }
    }
  }
}
