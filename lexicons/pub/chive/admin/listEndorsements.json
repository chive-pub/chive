{
  "lexicon": 1,
  "id": "pub.chive.admin.listEndorsements",
  "defs": {
    "main": {
      "type": "query",
      "description": "List indexed endorsements with pagination",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["total"],
          "properties": {
            "items": {
              "type": "array",
              "items": { "type": "ref", "ref": "#endorsementSummary" },
              "description": "Endorsement records"
            },
            "total": {
              "type": "integer",
              "description": "Total endorsements"
            }
          }
        }
      },
      "errors": [{ "name": "AuthenticationRequired" }, { "name": "AdminRequired" }]
    },
    "endorsementSummary": {
      "type": "object",
      "description": "Summary of an indexed endorsement",
      "required": ["uri", "eprintUri", "authorDid", "createdAt"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri", "description": "Endorsement AT URI" },
        "eprintUri": {
          "type": "string",
          "format": "at-uri",
          "description": "Endorsed eprint AT URI"
        },
        "authorDid": { "type": "string", "format": "did", "description": "Endorser DID" },
        "authorHandle": { "type": "string", "description": "Endorser handle" },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the endorsement was created"
        }
      }
    }
  }
}
