{
  "lexicon": 1,
  "id": "pub.chive.admin.getNodeMetrics",
  "revision": 1,
  "defs": {
    "main": {
      "type": "query",
      "description": "Get Node.js runtime metrics and process information",
      "parameters": {
        "type": "params",
        "properties": {}
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["metrics", "processInfo"],
          "properties": {
            "metrics": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#nodeMetric"
              },
              "description": "Node.js and process metric entries"
            },
            "processInfo": {
              "type": "ref",
              "ref": "#processInfo",
              "description": "Process runtime information"
            }
          }
        }
      },
      "errors": [
        {
          "name": "AuthenticationRequired"
        },
        {
          "name": "AdminRequired"
        }
      ]
    },
    "nodeMetric": {
      "type": "object",
      "description": "A Node.js runtime metric",
      "required": ["name", "value", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Metric name"
        },
        "value": {
          "type": "string",
          "description": "Current value (numeric string)"
        },
        "type": {
          "type": "string",
          "knownValues": ["counter", "gauge", "histogram"],
          "description": "Metric type"
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (bytes, seconds, percent)"
        }
      }
    },
    "processInfo": {
      "type": "object",
      "description": "Node.js process runtime information",
      "required": ["pid", "uptime", "heapUsed", "heapTotal", "rss"],
      "properties": {
        "pid": {
          "type": "integer",
          "description": "Process ID"
        },
        "uptime": {
          "type": "integer",
          "description": "Process uptime in seconds"
        },
        "heapUsed": {
          "type": "integer",
          "description": "V8 heap used in bytes"
        },
        "heapTotal": {
          "type": "integer",
          "description": "V8 heap total in bytes"
        },
        "rss": {
          "type": "integer",
          "description": "Resident set size in bytes"
        },
        "external": {
          "type": "integer",
          "description": "External memory in bytes"
        },
        "cpuUser": {
          "type": "integer",
          "description": "CPU user time in microseconds"
        },
        "cpuSystem": {
          "type": "integer",
          "description": "CPU system time in microseconds"
        },
        "eventLoopLag": {
          "type": "integer",
          "description": "Event loop lag in microseconds"
        }
      }
    }
  }
}
