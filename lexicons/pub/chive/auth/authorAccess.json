        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.getPendingClaims"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.approveClaim"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.rejectClaim"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.requestCoauthorship"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.approveCoauthor"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.rejectCoauthor"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.getCoauthorRequests"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.getMyCoauthorRequests"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.dismissSuggestion"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.actor.getMyRoles"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.actor.getMyProfile"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.actor.getDiscoverySettings"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.sync.registerPDS"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.sync.indexRecord"
