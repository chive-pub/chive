        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.collaboration.listInvites"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.collaboration.listCollaborators"
        }
