{
  "lexicon": 1,
  "id": "pub.chive.auth.authorAccess",
  "revision": 1,
  "defs": {
    "main": {
      "type": "permission-set",
      "description": "Author access for submitting and managing eprints on Chive.",
      "includes": ["pub.chive.auth.basicReader"],
      "permissions": [
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.submission"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.version"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.userTag"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.citation"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.relatedWork"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.eprint.changelog"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.actor.profile"
        },
        {
          "type": "permission",
          "resource": "repo",
          "collection": "pub.chive.actor.profileConfig"
