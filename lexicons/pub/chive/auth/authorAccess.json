        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.eprint.deleteSubmission"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.activity.getFeed"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.activity.log"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.activity.markFailed"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.discovery.getRecommendations"
