          "type": "permission",
          "resource": "blob",
          "accept": ["application/*", "image/*", "video/*", "audio/*", "text/*"]
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.startClaim"
        },
        {
          "type": "permission",
          "resource": "rpc",
          "lxm": "pub.chive.claiming.completeClaim"
        },
        {
          "type": "permission",
          "resource": "rpc",
